# Sage - 环境变量配置示例
# 复制为 .env 后填入实际值

# === LLM 配置（必需）===
# LLM API 密钥
LLM_API_KEY=sk-your-api-key-here
# LLM API 基础 URL（OpenAI 兼容接口）
LLM_BASE_URL=https://api.openai.com/v1
# 模型名称
LLM_MODEL=gpt-3.5-turbo
# 提供商类型: openai, claude, ollama, custom
LLM_PROVIDER=openai

# === Python 后端 ===
# Python 可执行文件路径（留空使用系统默认 python）
PYTHON_PATH=
# 后端监听端口
PYTHON_BACKEND_PORT=8765

# === 调试 ===
# 日志级别: debug, info, warning, error
LOG_LEVEL=info
