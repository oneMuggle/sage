{
  "name": "sage",
  "private": true,
  "version": "0.4.5-alpha.10",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "vite build --mode production && npx vite-bundle-visualizer",
    "preview": "vite preview",
    "lint": "eslint . --ignore-pattern dist-electron",
    "lint:fix": "eslint . --fix --ignore-pattern dist-electron",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:packaging": "vitest run tests/packaging/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'},null,2))\"",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "electron:dev": "npm run build:electron && electron .",
    "electron:build": "npm run build && npm run build:electron",
    "electron:dist": "npm run electron:build && electron-builder --publish never",
    "postinstall": "bash scripts/fix-chrome-sandbox.sh"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^1.7.17",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-virtual": "^3.14.3",
    "@uiw/react-codemirror": "^4.25.10",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^1.1.1",
    "electron-log": "^4.4.8",
    "lucide-react": "^0.294.0",
    "motion": "^12.41.0",
    "node-fetch": "^2.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.20.0",
    "react-syntax-highlighter": "^15.6.6",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.0",
    "sonner": "^2.0.7",
    "zod": "^4.4.3",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "autoprefixer": "^10.4.16",
    "electron": "^21.4.4",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "lefthook": "1.6",
    "postcss": "^8.4.32",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.0.8",
    "vitest": "^1.6.0"
  }
}
