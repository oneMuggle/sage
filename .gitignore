# ====================
# Sage .gitignore
# ====================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
.venv/
venv/
ENV/
env/
.env

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
.pnp
.pnp.js

# Build outputs
dist/
build/
*.tsbuildinfo

# Rust / Cargo
target/
# 注: Cargo.lock 必须 commit (应用程序, 非库)
# - CI 用 --locked 严格按此 lock 编译
# - Tauri 2.1.1 + Win7 + Rust 1.77.2 依赖图脆弱, lock 是唯一锚点

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# Database
*.db
*.sqlite
*.sqlite3
data/
# Re-include backend/data/ (Python module package) but still ignore
# runtime SQLite files. The bare `data/` rule would otherwise shadow
# `backend/data/*.py` for anyone adding a new repo module.
!backend/data/
backend/data/*.db
backend/data/*.sqlite
backend/data/*.sqlite3
# Runtime audit/JSONL ledgers written under backend/data/. These are
# created by the runtime, not part of the source tree.
backend/data/audit/*.jsonl

# Environment
.env
.env.local
.env.*.local

# OS
Thumbs.db
ehthumbs.db
Desktop.ini

# Test
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# Tauri
src-tauri/target/
src-tauri/gen/

# Test coverage reports
coverage/
.coverage

# Claude Code local config (per-developer)
.claude/

# Playwright MCP
.playwright-mcp/

# Electron builder
dist-electron/
release/
# Allow scripts/release/ (Sage tier inference + changelog tooling)
!scripts/release/

# Playwright
.playwright/
test-results/
playwright-report/
tests/electron/screenshots/

# VCRedist runtime bundled at build time (fetched by scripts/fetch-vcredist.ps1)
resources/vc_redist.x64.exe

# Build artifacts and release packages
release-artifacts/

# Reference files with sensitive credentials (API keys, tokens)
reference/

# Temporary screenshots
chat-*.png

# MCP Server build artifacts
packages/drawio-mcp-server/node_modules/
packages/drawio-mcp-server/dist/
