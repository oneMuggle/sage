{
    "name": "@sage/drawio-mcp-server",
    "version": "0.1.0",
    "description": "MCP server for sage - renders draw.io diagrams to SVG/PNG using headless browser",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "sage-drawio-mcp": "./dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.4",
        "linkedom": "^0.18.0",
        "puppeteer": "^24.0.0",
        "zod": "^4.0.0"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5"
    },
    "engines": {
        "node": ">=18"
    }
}
